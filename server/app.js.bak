app.listen(PORT, '0.0.0.0',() => {
  console.log(`========================================`);
  console.log(`  🚀 MRZ API Server`);
  console.log(`  📍 http://localhost:${PORT}`);
  console.log(`========================================`);
  console.log(`  POST /api/scan     - Escanear carnet`);
